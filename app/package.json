{
  "name": "petory-app",
  "version": "0.0.1",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:dev-client": "expo start --dev-client --lan",
    "start:tunnel": "expo start --tunnel",
    "web": "expo start --web",
    "android": "ANDROID_HOME=$HOME/Library/Android/sdk ANDROID_SDK_ROOT=$HOME/Library/Android/sdk JAVA_HOME=$(/usr/libexec/java_home -v 21) expo run:android",
    "android:prebuild": "npx expo prebuild --platform android --no-install",
    "android:assemble:debug": "cd android && ANDROID_HOME=$HOME/Library/Android/sdk ANDROID_SDK_ROOT=$HOME/Library/Android/sdk JAVA_HOME=$(/usr/libexec/java_home -v 21) ./gradlew assembleDebug",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/messaging": "^21.14.0",
    "expo": "^55.0.8",
    "expo-dev-client": "~55.0.18",
    "expo-image-picker": "~55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.75.2",
    "@types/react": "^19.2.2",
    "babel-preset-expo": "~11.0.10",
    "typescript": "^5.9.3"
  }
}
